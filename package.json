{
  "name": "docraptor-client",
  "version": "1.0.0",
  "description": "HTML-to-PDF client for docraptor",
  "main": "index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "start:prod": "pm2 start index.js --name docraptor-client",
    "stop:prod": "pm2 stop docraptor-client",
    "restart:prod": "pm2 restart docraptor-client",
    "test": "jest --detectOpenHandles --forceExit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:md": "markdownlint '**/*.md' --ignore node_modules --ignore reports --ignore docs/generated",
    "lint:cpd": "jscpd . --config .jscpd.json",
    "lint:cpd:ci": "jscpd . --config .jscpd.json --threshold 5",
    "links": "command -v lychee >/dev/null 2>&1 && lychee --no-progress '**/*.md' || echo 'skip: lychee not installed (run scripts/bootstrap.sh)'",
    "security:audit": "npm audit --audit-level=high",
    "security:check": "npm audit --audit-level=high",
    "security:osv": "command -v osv-scanner >/dev/null 2>&1 && osv-scanner --lockfile=package-lock.json || echo 'skip: osv-scanner not installed (run scripts/bootstrap.sh)'",
    "security:semgrep": "command -v semgrep >/dev/null 2>&1 && semgrep --config=p/javascript --config=p/nodejsscan --config=p/express --config=p/owasp-top-ten --error --metrics=off || echo 'skip: semgrep not installed (run scripts/bootstrap.sh)'",
    "security:secrets": "command -v gitleaks >/dev/null 2>&1 && gitleaks detect --no-banner --redact || echo 'skip: gitleaks not installed (run scripts/bootstrap.sh)'",
    "security": "npm run security:audit && npm run security:osv && npm run security:semgrep && npm run security:secrets",
    "license:check": "license-checker-rseidelsohn --production --onlyAllow 'MIT;ISC;Apache-2.0;BSD-2-Clause;BSD-3-Clause;0BSD;CC0-1.0;Unlicense;Python-2.0;WTFPL;BlueOak-1.0.0' --excludePrivatePackages --summary",
    "license:report": "license-checker-rseidelsohn --production --csv --out reports/licenses.csv",
    "check": "npm run lint && npm run format:check && npm run lint:md",
    "check:all": "npm run check && npm test && npm run lint:cpd:ci && npm run license:check && npm run links",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write --ignore-unknown"
    ],
    "*.md": [
      "markdownlint",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/karlgroves/docraptor-client.git"
  },
  "author": "Karl Groves <karlgroves@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/karlgroves/docraptor-client/issues"
  },
  "homepage": "https://github.com/karlgroves/docraptor-client#readme",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.985.0",
    "axios": "^1.7.2",
    "bunyan": "^1.8.15",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "envalid": "^8.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-import-x": "^4.0.0",
    "eslint-plugin-jsdoc": "^50.0.0",
    "eslint-plugin-n": "^17.0.0",
    "eslint-plugin-no-secrets": "^1.0.2",
    "eslint-plugin-promise": "^7.0.0",
    "eslint-plugin-security": "^3.0.0",
    "eslint-plugin-sonarjs": "^2.0.0",
    "eslint-plugin-unicorn": "^56.0.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "jscpd": "^4.0.0",
    "license-checker-rseidelsohn": "^4.4.0",
    "lint-staged": "^15.0.0",
    "markdownlint-cli": "^0.47.0",
    "nodemon": "^3.1.4",
    "pm2": "^5.4.1",
    "prettier": "^3.3.2",
    "supertest": "^7.0.0"
  }
}
